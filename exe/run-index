#!/usr/bin/env ruby
# encoding: utf-8

# Index all markdown files in configured SQLite tables.
#
# Usage:
#   run-index [--allow-empty-prune] [config.json]
#
# Requires provider API keys for configured providers.

require "json"
require "digest"
require "stringio"
require "thread"
require "set"
begin
  require "bundler/setup"
rescue LoadError
end

require_relative "../llm/llm"
require_relative "../llm/embedding"
require_relative "../readers/reader"
require_relative "../lib/config_loader"
require_relative "../lib/config_path_resolver"
require_relative "../lib/ollama_service"
require_relative "../lib/provider_env_validator"
require_relative "../storage/sqlite_index"

def usage_text
  <<~USAGE
    Usage: run-index [--allow-empty-prune] [config.json]

    Options:
      --allow-empty-prune  Allow deleting stale rows when a path scan returns zero files.
      -h, --help           Show this help.
  USAGE
end

def parse_cli_args(argv)
  opts = { allow_empty_prune: false, config_arg: nil }

  argv.each do |arg|
    case arg
    when "--allow-empty-prune"
      opts[:allow_empty_prune] = true
    when "-h", "--help"
      STDOUT << usage_text
      exit 0
    when /\A-/
      raise ArgumentError, "Unknown option: #{arg}"
    else
      if opts[:config_arg]
        raise ArgumentError, "Invalid arguments received, expected at most one config file path"
      end
      opts[:config_arg] = arg
    end
  end

  opts
end

begin
  cli = parse_cli_args(ARGV)
rescue ArgumentError => e
  STDOUT << "#{e.message}\n\n"
  STDOUT << usage_text
  exit 1
end

config_file = ConfigPathResolver.resolve_config_path(cli[:config_arg])
unless config_file
  STDOUT << "#{ConfigPathResolver.default_search_message}\n"
  exit 1
end

begin
  CONFIG = ConfigLoader.load_config(config_file)
rescue => e
  STDOUT << "Config error: #{e.message}\n"
  exit 1
end

STDOUT << "Using config: #{config_file}\n"
STDOUT << "allow_empty_prune=#{cli[:allow_empty_prune]}\n"

exit 9 unless OllamaService.ensure_started(CONFIG)

missing_key_msg = ProviderEnvValidator.missing_key_message(CONFIG)
if missing_key_msg
  STDOUT << "#{missing_key_msg}\n"
  exit 9
end

def each_scanned_file(path, out, status_cb)
  return enum_for(__method__, path, out, status_cb) unless block_given?

  status_cb.call("Scanning dir")
  name_match = path.nameMatch || "*.{md,markdown}"
  dir_blob = File.join(File.expand_path(path.dir), "**", name_match)
  out << "Scan dir: #{dir_blob}\n"
  Dir.glob(dir_blob) do |file|
    next unless File.file?(file)

    yield file
  end
end

def reader_class_or_exit(path, out)
  reader_class = get_reader(path.reader)
  if reader_class.nil?
    out << "Reader undefinied: #{path.reader}\n"
    exit 9
  end
  reader_class
end

class IndexChunkSplitter
  include ChunkUtils
end

INDEX_CHUNK_SPLITTER = IndexChunkSplitter.new
INDEX_MAX_EMBED_TOKENS = cfg(:embedding, "max_tokens", 512).to_i
INDEX_MIN_EMBED_TOKENS = cfg(:embedding, "min_tokens", ChunkUtils::DEFAULT_MIN_TOKENS).to_i

def normalize_index_chunks(chunks)
  chunks.flat_map do |chunk|
    INDEX_CHUNK_SPLITTER.split_chunk_by_tokens(chunk, INDEX_MAX_EMBED_TOKENS)
  end.then do |split_chunks|
    INDEX_CHUNK_SPLITTER.filter_small_chunks(split_chunks, INDEX_MIN_EMBED_TOKENS)
  end
end

def index_path_sqlite(path, out, status_cb, log_cb, allow_empty_prune:)
  out << "Read path name: #{path.name}, reader: #{path.reader}\n"
  status_cb.call("Reading index")

  out << "Read existing sqlite index: #{path.db_file}@#{path.db_table}, time: @#{Time.now}\n"
  store = SqliteIndex.new(path.db_file, path.db_table)
  out << "Found index rows: #{store.row_count}\n"

  files = each_scanned_file(path, out, status_cb)
  reader_class = reader_class_or_exit(path, out)
  error_count = 0
  prune_skipped = false
  indexed_files = 0

  out << "Building index @#{Time.now}\n["
  status_cb.call("Indexing files, created=0, skipped=0, errors=0")
  skipped = 0
  created = 0
  scanned_files = Set.new

  begin
    files.each do |file|
      indexed_files += 1
      status_cb.call("Indexing #{indexed_files} files, created=#{created}, skipped=#{skipped}, errors=#{error_count}")
      begin
        chunks = normalize_index_chunks(reader_class.new(file).load.chunks)
      rescue => e
        error_count += 1
        out << "\nError reading #{file}: #{e.class}: #{e.message}\n"
        out << "Backtrace: #{e.backtrace&.first}\n"
        log_cb.call("[#{path.name}] Error reading #{file}: #{e.class}: #{e.message}")
        next
      end

      valid_chunks = Set.new
      pending_rows = []
      file_chunk_hashes = store.chunk_hash_lookup_for_path(file)
      chunk_rows = []
      changed_hashes = Set.new

      chunks.each_with_index do |chunk, chunk_idx|
        begin
          hash = Digest::SHA256.hexdigest(chunk)
          chunk_rows << [chunk_idx, chunk, hash]
          valid_chunks.add(chunk_idx)
          next if file_chunk_hashes[chunk_idx] == hash

          changed_hashes.add(hash)
        rescue => e
          error_count += 1
          out << "\nError indexing file=#{file}, chunk=#{chunk_idx}: #{e.class}: #{e.message}\n"
          out << "Hash: #{hash}\n" if defined?(hash)
          out << "Backtrace: #{e.backtrace&.first}\n"
          log_cb.call("[#{path.name}] Error indexing #{file} chunk #{chunk_idx}: #{e.class}: #{e.message}")
          next
        end
      end

      begin
        existing_embeddings = store.embeddings_for_hashes(changed_hashes.to_a)
      rescue => e
        error_count += 1
        out << "\nError loading existing embeddings for file=#{file}: #{e.class}: #{e.message}\n"
        out << "Backtrace: #{e.backtrace&.first}\n"
        log_cb.call("[#{path.name}] Error loading existing embeddings for #{file}: #{e.class}: #{e.message}")
        existing_embeddings = {}
      end

      chunk_rows.each do |chunk_idx, chunk, hash|
        begin
          if file_chunk_hashes[chunk_idx] == hash
            skipped += 1
            next
          end

          emb = existing_embeddings[hash]
          if emb.nil?
            emb = embedding(chunk)
            created += 1
            existing_embeddings[hash] = emb
          end

          raise "Embedding missing for hash=#{hash}" if emb.nil?

          normalized = normalize_embedding(emb)
          bucket = bucket_key(normalized)

          pending_rows << {
            path: file,
            chunk: chunk_idx,
            hash: hash,
            embedding: emb,
            bucket: bucket,
            text: chunk
          }
          file_chunk_hashes[chunk_idx] = hash
        rescue => e
          error_count += 1
          out << "\nError indexing file=#{file}, chunk=#{chunk_idx}: #{e.class}: #{e.message}\n"
          out << "Hash: #{hash}\n" if defined?(hash)
          out << "Backtrace: #{e.backtrace&.first}\n"
          log_cb.call("[#{path.name}] Error indexing #{file} chunk #{chunk_idx}: #{e.class}: #{e.message}")
          next
        end
      end

      store.transaction do
        pending_rows.each { |row| store.upsert_chunk(row) }
        store.delete_stale_chunks(file, valid_chunks)
      end

      scanned_files.add(file)

      if (indexed_files - 1) % 50 == 0
        out << (indexed_files - 1)
      else
        out << "."
      end
    end

    if indexed_files == 0 && !allow_empty_prune
      out << "Empty scan guard: skipping stale prune for #{path.name}. Re-run with --allow-empty-prune to allow pruning on empty scan.\n"
      status_cb.call("Empty scan guard active; prune skipped")
      prune_skipped = true
    end

    if indexed_files == 0 && allow_empty_prune
      out << "\nallow-empty-prune enabled: pruning all rows in table #{path.db_table} due to empty scan.\n"
    end

    unless prune_skipped
      store.transaction do
        store.delete_stale_paths(scanned_files.to_a)
      end
    end
  ensure
    store.close
  end

  out << "]\nDone @#{Time.now}, Created: #{created}, Skipped: #{skipped}, Errors: #{error_count}\n"
  status_cb.call("Done. created=#{created}, skipped=#{skipped}, errors=#{error_count}")
  { created: created, skipped: skipped, errors: error_count, files: indexed_files, prune_skipped: prune_skipped }
end

def index_path(path, out, status_cb, log_cb, allow_empty_prune:)
  unless path.db_file && path.db_table
    raise ArgumentError, %(Path "#{path.name}" must set "db". JSONL indexing has been removed.)
  end

  index_path_sqlite(path, out, status_cb, log_cb, allow_empty_prune: allow_empty_prune)
end

status_mutex = Mutex.new
status_map = {}
log_lines = []

status_cb = lambda do |name, msg|
  status_mutex.synchronize { status_map[name] = msg }
end

log_cb = lambda do |line|
  status_mutex.synchronize do
    log_lines << line
    log_lines.shift while log_lines.length > 20
  end
end

printer = Thread.new do
  next unless STDOUT.tty?
  loop do
    lines = nil
    logs = nil
    status_mutex.synchronize do
      lines = status_map.map { |k, v| "#{k}: #{v}" }
      logs = log_lines.dup
    end
    STDOUT << "\e[2J\e[H"
    STDOUT << "Index status (live)\n"
    lines.each { |l| STDOUT << l << "\n" }
    STDOUT << "\nRecent errors\n"
    if logs.empty?
      STDOUT << "(none)\n"
    else
      logs.each { |l| STDOUT << l << "\n" }
    end
    STDOUT.flush
    sleep 0.2
  end
end

threads = CONFIG.paths.map do |path|
  Thread.new do
    buffer = StringIO.new
    failed = false
    summary = nil
    begin
      status_cb.call(path.name, "Starting")
      summary = index_path(
        path,
        buffer,
        ->(msg) { status_cb.call(path.name, msg) },
        log_cb,
        allow_empty_prune: cli[:allow_empty_prune]
      )
      failed = summary[:errors].to_i > 0
    rescue => e
      failed = true
      buffer << "\nThread error: #{e.class}: #{e.message}\n"
      buffer << "Backtrace: #{e.backtrace&.first}\n"
    ensure
      Thread.current[:output] = buffer.string
      Thread.current[:path_name] = path.name
      Thread.current[:failed] = failed
      Thread.current[:summary] = summary
      status_cb.call(path.name, failed ? "Failed" : "Finished")
    end
  end
end

threads.each(&:join)
printer.kill if printer&.alive?

threads.each do |t|
  name = t[:path_name] || "path"
  STDOUT << "\n=== Index output: #{name} ===\n"
  STDOUT << (t[:output] || "")
  STDOUT << "\n=== End: #{name} ===\n"
end

failed_paths = threads.filter_map do |t|
  next unless t[:failed]
  t[:path_name] || "path"
end

if failed_paths.any?
  STDOUT << "\nIndex completed with failures: #{failed_paths.join(', ')}\n"
  exit 1
end
