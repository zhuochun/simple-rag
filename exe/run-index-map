#!/usr/bin/env ruby
# encoding: utf-8

# Build cognition-map data from indexed notes.
#
# Usage:
#   run-index-map config.json
#   run-index-map config.json journal,learning
#   run-index-map config.json '["journal","learning"]'
#
# Notes:
# - Run this after `run-index` (or after `run-migrate` if you use sqlite).
# - `map.path` is REQUIRED in config.json.
# - Optional path filtering can come from:
#   - CLI second argument, or
#   - config.json field: map.includePaths

