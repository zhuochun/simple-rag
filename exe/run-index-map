  retry_note = attempt > 1 ? "    - This is retry #{attempt}. The previous answer failed validation; choose a different valid label.\n" : ""
  used_block = used_xml.empty? ? "" : <<~USED

    Already used labels. Do not reuse any of these:
    <used_labels>
#{used_xml}
