def generate_cluster_labels(cluster_samples)
  return {} if cluster_samples.empty?

  labels = {}
  used_label_keys = Set.new
  used_label_texts = []
  cluster_samples.each do |cluster_sample|
    cluster_index = cluster_sample[:cluster_index]
    rejected_labels = []
    assigned_label = nil

    (1..MAX_LABEL_ATTEMPTS).each do |attempt|
      raw_response = nil
      begin
        prompt = build_label_prompt(
          cluster_sample,
          used_labels: used_label_texts,
          rejected_labels: rejected_labels,
          attempt: attempt
        )
        raw_response = chat([
          { role: ROLE_SYSTEM, content: "You output only the final map label text." },
          { role: ROLE_USER, content: prompt }
        ]).to_s

        label = sanitize_label(raw_response)
        if label.empty?
          add_rejected_label(rejected_labels, raw_response)
          log_label_warning(
            "Empty label from LLM for cluster #{cluster_index} (attempt #{attempt}/#{MAX_LABEL_ATTEMPTS})",
            response: raw_response
          )
          next
        end

        key = label_key(label)
        if used_label_keys.include?(key)
          add_rejected_label(rejected_labels, label)
          log_label_warning(
            "Duplicate label from LLM for cluster #{cluster_index}: #{label} (attempt #{attempt}/#{MAX_LABEL_ATTEMPTS})",
            response: raw_response
          )
          next
        end

        assigned_label = label
        break
      rescue => e
        add_rejected_label(rejected_labels, raw_response) unless raw_response.nil?
        log_label_warning(
          "LLM label generation failed for cluster #{cluster_index} (attempt #{attempt}/#{MAX_LABEL_ATTEMPTS})",
          response: raw_response,
          exception: e
        )
      end
    end

    if assigned_label.to_s.strip.empty?
      assigned_label = fallback_label(cluster_sample[:snippets], cluster_index, used_label_keys)
      log_label_warning(
        "Using fallback label for cluster #{cluster_index}: #{assigned_label}"
      )
    end

    labels[cluster_index] = assigned_label
    used_label_keys.add(label_key(assigned_label))
    used_label_texts << assigned_label
  end

  labels
end

def prepare_notes_for_map!(notes)
  raise "No notes available. Run run-index first." if notes.empty?

  vector_dim = nil
  notes.each_with_index do |note, idx|
    emb = note[:embedding]
    if emb.nil? || emb.empty?
      raise "Missing embedding for note index #{idx} (#{note[:path]}##{note[:chunk]})"
    end
    vector_dim ||= emb.length
    if emb.length != vector_dim
      raise "Embedding dimension mismatch: expected=#{vector_dim}, got=#{emb.length}, note=#{note[:path]}##{note[:chunk]}"
    end
    normalized = safe_normalize(emb)
    raise "Zero-norm embedding at #{note[:path]}##{note[:chunk]}" if normalized.nil?
    note[:embedding] = normalized
  end

  vector_dim
end

def build_map_payload(notes, points, assignments, members, final_stats, vector_dim, layout_meta: nil, degree_scores: nil)
  members_sorted = members.keys.sort_by { |cid| [-members[cid].length, cid] }
  cluster_samples = cluster_samples_for_labels(
    notes,
    points,
    members,
    final_stats,
    degree_scores: degree_scores,
    ordered_cluster_ids: members_sorted
  )
  cluster_sample_by_id = {}
  cluster_samples.each { |sample| cluster_sample_by_id[sample[:cluster_id]] = sample }
  llm_labels = generate_cluster_labels(cluster_samples)

  cluster_id_order_map = {}
  final_label_keys = Set.new
  clusters = members_sorted.each_with_index.map do |cid, order_idx|
    stat = final_stats[cid]
    cluster_index = order_idx + 1
    cluster_id = "mountain-#{cluster_index}"
    cluster_id_order_map[cid] = cluster_id

    snippets = cluster_sample_by_id.fetch(cid, { snippets: [] })[:snippets]
    label = llm_labels[cluster_index]
    if label.to_s.strip.empty?
      label = fallback_label(snippets, cluster_index, final_label_keys)
    end
    key = label_key(label)
    if final_label_keys.include?(key)
      label = fallback_label(snippets, cluster_index, final_label_keys)
      key = label_key(label)
    end
    final_label_keys.add(key)

    {
      id: cluster_id,
      label: label,
      centerX: stat[:cx].round(2),
      centerY: stat[:cy].round(2),
      spreadX: (stat[:dx] + 36.0).round(2),
      spreadY: (stat[:dy] + 36.0).round(2),
      noteCount: stat[:count]
    }
  end

  notes_payload = notes.each_with_index.map do |n, idx|
    cid = assignments[idx]
    {
      id: "#{n[:lookup]}::#{n[:path]}##{n[:chunk]}",
      lookup: n[:lookup],
      path: n[:path],
      chunk: n[:chunk],
      hash: n[:hash],
      title: n[:id],
      url: n[:url],
      snippet: map_snippet(n[:text]),
      x: points[idx][0].round(2),
      y: points[idx][1].round(2),
      clusterId: cluster_id_order_map[cid]
    }
  end

  payload = {
    generatedAt: Time.now.utc.iso8601,
    noteCount: notes_payload.length,
    vectorDim: vector_dim,
    width: MAP_WIDTH,
    height: MAP_HEIGHT,
    clusters: clusters,
    notes: notes_payload
  }
  payload[:layout] = layout_meta if layout_meta
  payload
end

def build_map_data_with_kmeans(notes, vector_dim:, fallback_reason: nil)
  embeddings = notes.map { |n| n[:embedding] }
  a_idx, b_idx, c_idx = choose_anchor_indices(embeddings)
  a = embeddings[a_idx]
  b = embeddings[b_idx]
  c = embeddings[c_idx]

  raw_x = embeddings.map { |e| dot2(e, a) - dot2(e, b) }
  raw_y = embeddings.map { |e| dot2(e, c) - 0.5 * (dot2(e, a) + dot2(e, b)) }

  px = normalize_to_canvas(raw_x, MAP_MARGIN, MAP_WIDTH - MAP_MARGIN)
  py = normalize_to_canvas(raw_y, MAP_MARGIN, MAP_HEIGHT - MAP_MARGIN)
  points = px.each_with_index.map { |x, i| [x, py[i]] }

  k = desired_cluster_count(notes.length)
  centers, assignments = kmeans(points, k, "map-kmeans:#{notes.length}:#{vector_dim}")
  centers, assignments = merge_small_clusters(points, centers, assignments)

  members = build_members_from_assignments(assignments)
  before_stats = compute_cluster_stats(points, members)
  spread_centers = spread_cluster_centers(before_stats)
  reposition_points!(points, members, before_stats, spread_centers)
  final_stats = compute_cluster_stats(points, members)

  layout_meta = { method: "kmeans" }
  layout_meta[:fallbackReason] = fallback_reason if fallback_reason
  build_map_payload(notes, points, assignments, members, final_stats, vector_dim, layout_meta: layout_meta)
end

def build_map_data_with_graph(notes, vector_dim:)
  k = graph_knn_k(notes.length)
  min_size = graph_community_min_size
  min_edge_weight = graph_edge_min_weight
  iterations = map_layout_iterations

  directed_edges = build_knn_edges_with_sqlite_vec(notes, k: k, vector_dim: vector_dim)
  graph = symmetrize_knn_edges(directed_edges, node_count: notes.length, min_weight: min_edge_weight)
  adjacency = graph[:adjacency]
  edges = graph[:edges]
  STDOUT << "Undirected edges: #{edges.length}\n"

  assignments = detect_communities_weighted_local_moving(adjacency, min_size: min_size)
  assignments.each_with_index { |cid, idx| notes[idx][:community_id] = cid }
  members = build_members_from_assignments(assignments)
  STDOUT << "Detected communities: #{members.length}\n"
  STDOUT << "Running force layout: iterations=#{iterations}\n"

  points = layout_graph_force(
    adjacency,
    assignments,
    iterations: iterations,
    width: MAP_WIDTH,
    height: MAP_HEIGHT,
    margin: MAP_MARGIN
  )
  final_stats = compute_cluster_stats(points, members)
  degree_scores = community_weighted_degrees(adjacency, members)

  layout_meta = {
    method: "graph",
    knnK: k,
    communityMethod: "weighted_local_moving",
    layoutMethod: "force_directed",
    edgeCount: edges.length
  }
  build_map_payload(
    notes,
    points,
    assignments,
    members,
    final_stats,
    vector_dim,
    layout_meta: layout_meta,
    degree_scores: degree_scores
  )
end

def build_map_data(notes)
  vector_dim = prepare_notes_for_map!(notes)
  requested_layout = map_layout_requested
  requested_layout ||= MAP_LAYOUT_DEFAULT
  STDOUT << "Map layout requested: #{requested_layout}\n"
  STDOUT << "sqlite-vec available: #{sqlite_vec_available?}\n"

  if graph_layout_enabled?
    STDOUT << "Map layout: graph\n"
    begin
      return build_map_data_with_graph(notes, vector_dim: vector_dim)
    rescue GraphDependencyError => e
      STDOUT << "sqlite-vec unavailable on this platform; falling back to kmeans layout\n"
      return build_map_data_with_kmeans(notes, vector_dim: vector_dim, fallback_reason: e.message)
    end
  end

  if requested_layout == "graph" && !sqlite_vec_available?
    STDOUT << "sqlite-vec unavailable on this platform; falling back to kmeans layout\n"
    return build_map_data_with_kmeans(notes, vector_dim: vector_dim, fallback_reason: "sqlite-vec unavailable")
  end

  STDOUT << "Map layout: kmeans\n"
  build_map_data_with_kmeans(notes, vector_dim: vector_dim)
end

