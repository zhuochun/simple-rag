def graph_edge_min_weight
  value = map_float_config(:graphEdgeMinWeight, default: MAP_GRAPH_EDGE_MIN_WEIGHT_DEFAULT)
  raise ArgumentError, "Invalid map.graphEdgeMinWeight: must be >= 0.0" if value < 0.0
  [value, 1.0].min
end

