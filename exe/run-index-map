  map_out_file = map_out_file!

  if should_start_ollama?
    ok = OllamaService.ensure_started(CONFIG)
    exit 9 unless ok
  end

  target_paths = resolve_target_paths
  STDOUT << "Selected paths: #{target_paths.map(&:name).join(", ")}\n"

  notes = load_all_notes(target_paths)
  map_data = build_map_data(notes)

  out_dir = File.dirname(map_out_file)
  FileUtils.mkdir_p(out_dir) unless Dir.exist?(out_dir)
  File.write(map_out_file, JSON.pretty_generate(map_data))

  STDOUT << "Map data generated: #{map_out_file}\n"
  STDOUT << "Notes: #{map_data[:noteCount]}, mountains: #{map_data[:clusters].length}, vector_dim: #{map_data[:vectorDim]}\n"
rescue => e
  STDOUT << "run-index-map failed: #{e.class}: #{e.message}\n"
  STDOUT << "Backtrace: #{e.backtrace&.first}\n"
  exit 1
end
