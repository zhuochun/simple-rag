def parse_include_names(raw)
  return nil if raw.nil? || raw.to_s.strip.empty?

  txt = raw.to_s.strip
  arr = if txt.start_with?("[")
    parsed = JSON.parse(txt)
    unless parsed.is_a?(Array)
      raise ArgumentError, "Path filter must be a JSON array when using bracket syntax"
    end
    parsed
  else
    txt.split(",")
  end

  names = arr.map(&:to_s).map(&:strip).reject(&:empty?).uniq
  raise ArgumentError, "Path filter is empty" if names.empty?
  names
end

def config_include_names
  raw = map_config_value(:includePaths)
  return nil if raw.nil?

  arr = raw.is_a?(Array) ? raw : [raw]
  names = arr.map(&:to_s).map(&:strip).reject(&:empty?).uniq
  raise ArgumentError, "map.includePaths is present but empty" if names.empty?
  names
end

def resolve_target_paths
  cli_names = parse_include_names(CLI_INCLUDE_RAW)
  names = cli_names || config_include_names
  return CONFIG.paths if names.nil?

  known_names = CONFIG.paths.map(&:name)
  unknown = names - known_names
  unless unknown.empty?
    raise ArgumentError, %(Unknown path names in include filter: #{unknown.join(", ")})
  end

  selected = CONFIG.paths.select { |p| names.include?(p.name) }
  raise ArgumentError, "No paths selected for map generation" if selected.empty?
  selected
end

def map_out_file!
  configured = map_config_value(:path).to_s.strip
  if configured.empty?
    raise ArgumentError, %(Config field "map.path" is required for run-index-map)
  end

  path = Pathname.new(configured)
  path.absolute? ? path.to_s : File.expand_path(configured, CONFIG_BASE_DIR)
end

def log_label_warning(reason, response: nil, exception: nil)
  lines = []
  lines << "[LabelWarning #{Time.now.utc.iso8601}] #{reason}"
  lines << "Exception: #{exception.class}: #{exception.message}" if exception
  if response && !response.to_s.strip.empty?
    clipped = response.to_s
    clipped = clipped[0, 2400] + "...(truncated)" if clipped.length > 2400
    lines << "LLM response: #{clipped}"
  end
  STDOUT << lines.join("\n") << "\n"
end

def safe_float_array(raw)
  arr = raw.is_a?(Array) ? raw : JSON.parse(raw.to_s)
  arr.map { |v| v.to_f }
end

def safe_normalize(vec)
  norm = Math.sqrt(vec.inject(0.0) { |s, v| s + (v * v) })
  return nil if norm <= 0.0
  vec.map { |v| v / norm }
end

def dot2(a, b)
  sum = 0.0
  a.each_with_index { |v, i| sum += v * b[i] }
  sum
end

def cosine_distance(a, b)
  1.0 - dot2(a, b)
end

class GraphDependencyError < StandardError; end

def vec_literal(vec)
  JSON.generate(vec.map(&:to_f))
end

def distance_to_weight(distance)
  cosine = 1.0 - ((distance.to_f * distance.to_f) / 2.0)
  [[cosine, 0.0].max, 1.0].min
end

def open_vec_db
  unless sqlite_vec_available?
    raise GraphDependencyError, "sqlite-vec unavailable on this platform"
  end

  db = SQLite3::Database.new(":memory:")
  db.results_as_hash = true
  begin
    db.enable_load_extension(true)
  rescue
    # ignore: some sqlite3 builds disallow extension loading
  end

  begin
    SqliteVec.load(db)
  rescue LoadError => e
    raise GraphDependencyError, "sqlite-vec gem load failed: #{e.message}"
  rescue => e
    raise GraphDependencyError, "sqlite-vec extension init failed: #{e.class}: #{e.message}"
  ensure
    begin
      db.enable_load_extension(false)
    rescue
      # ignore
    end
  end

  begin
    db.get_first_value("SELECT vec_version()")
  rescue => e
    raise GraphDependencyError, "sqlite-vec health check failed: #{e.class}: #{e.message}"
  end

  db
end

def build_knn_edges_with_sqlite_vec(notes, k:, vector_dim:)
  STDOUT << "Building kNN graph with sqlite-vec: notes=#{notes.length}, dim=#{vector_dim}, k=#{k}\n"
  db = open_vec_db
  db.execute("CREATE VIRTUAL TABLE vec_notes USING vec0(embedding float[#{vector_dim}])")

  db.transaction do
    notes.each_with_index do |note, idx|
      note[:map_idx] = idx
      db.execute(
        "INSERT INTO vec_notes(rowid, embedding) VALUES(?, ?)",
        [idx + 1, vec_literal(note[:embedding])]
      )
    end
  end

  directed = []
  notes.length.times do |src_idx|
    query = vec_literal(notes[src_idx][:embedding])
    rows = db.execute(
      "SELECT rowid, distance FROM vec_notes WHERE embedding MATCH ? AND k = ? ORDER BY distance",
      [query, k + 1]
    )
    rows.each do |row|
      dst_idx = (row["rowid"] || row[0]).to_i - 1
      next if dst_idx == src_idx
      next if dst_idx < 0 || dst_idx >= notes.length

      directed << [src_idx, dst_idx, distance_to_weight(row["distance"] || row[1])]
    end
  end
  db.close

  STDOUT << "Built directed kNN edges: #{directed.length}\n"
  directed
rescue SQLite3::Exception => e
  message = e.message.to_s.downcase
  if message.include?("no such module: vec0") ||
     message.include?("no such function: vec_version") ||
     message.include?("no such function: vec_distance") ||
     message.include?("unable to open shared library")
    raise GraphDependencyError, "sqlite-vec query unavailable: #{e.message}"
  end
  raise
ensure
  begin
    db&.close
  rescue
    # ignore
  end
end

def build_knn_edges_with_ruby(notes, k:)
  STDOUT << "Building kNN graph with pure Ruby: notes=#{notes.length}, k=#{k}\n"
  directed = []
  embeddings = notes.map { |note| note[:embedding] }

  embeddings.each_with_index do |src_embedding, src_idx|
    neighbors = []
    embeddings.each_with_index do |dst_embedding, dst_idx|
      next if src_idx == dst_idx

      weight = dot2(src_embedding, dst_embedding)
      weight = [[weight, 0.0].max, 1.0].min
      neighbors << [dst_idx, weight]
    end

    neighbors
      .sort_by { |dst_idx, weight| [-weight, dst_idx] }
      .first(k)
      .each { |dst_idx, weight| directed << [src_idx, dst_idx, weight] }
  end

  STDOUT << "Built directed kNN edges: #{directed.length}\n"
  directed
end

def build_knn_edges(notes, k:, vector_dim:)
  if sqlite_vec_available?
    build_knn_edges_with_sqlite_vec(notes, k: k, vector_dim: vector_dim)
  else
    build_knn_edges_with_ruby(notes, k: k)
  end
rescue GraphDependencyError => e
  STDOUT << "#{e.message}; using pure Ruby kNN graph\n"
  build_knn_edges_with_ruby(notes, k: k)
end

def symmetrize_knn_edges(directed_edges, node_count:, min_weight:)
  pair_weights = {}
  directed_edges.each do |src, dst, weight|
    next if src == dst
    a, b = src < dst ? [src, dst] : [dst, src]
    pair_weights[[a, b]] ||= {}
    pair_weights[[a, b]][[src, dst]] = weight.to_f
  end

  adjacency = Array.new(node_count) { {} }
  edges = []
  pair_weights.each do |(a, b), directed|
    wab = directed[[a, b]]
    wba = directed[[b, a]]
    mutual = !wab.nil? && !wba.nil?
    weight = if wab && wba
      [wab, wba].max * 1.15
    else
      (wab || wba).to_f
    end
    weight = [[weight, 0.0].max, 1.0].min
    next if weight < min_weight

    adjacency[a][b] = weight
    adjacency[b][a] = weight
    edges << { source: a, target: b, weight: weight, mutual: mutual }
  end

  {
    node_count: node_count,
    adjacency: adjacency,
    edges: edges
  }
end

def graph_from_edges(edges, node_count:)
  adjacency = Array.new(node_count) { {} }
  edges.each do |edge|
    a = edge[:source]
    b = edge[:target]
    weight = edge[:weight].to_f
    adjacency[a][b] = weight
    adjacency[b][a] = weight
  end
  { node_count: node_count, adjacency: adjacency, edges: edges }
end

def retain_layout_edges(edges, communities, cross_per_node:)
  retained = {}
  cross_by_node = Hash.new { |h, k| h[k] = [] }

  edges.each do |edge|
    a = edge[:source]
    b = edge[:target]
    same = communities[a] == communities[b]
    key = a < b ? [a, b] : [b, a]

    if same || edge[:mutual]
      retained[key] = edge.merge(same_community: same, bridge: !same)
    end

    next if same

    cross_by_node[a] << edge
    cross_by_node[b] << edge
  end

  cross_by_node.each_value do |node_edges|
    node_edges.sort_by { |edge| [-edge[:weight].to_f, edge[:source], edge[:target]] }
      .first(cross_per_node)
      .each do |edge|
        a = edge[:source]
        b = edge[:target]
        key = a < b ? [a, b] : [b, a]
        retained[key] = edge.merge(same_community: false, bridge: true)
      end
  end

  retained.values.sort_by { |edge| [edge[:source], edge[:target]] }
end

def extract_id(file_path)
  path = Pathname.new(file_path)
  segments = path.each_filename.to_a
  return File.basename(file_path) if segments.length < 2
  File.join(segments[-2], segments[-1])
end

def extract_url(file_path, url_prefix)
  if url_prefix
    path = Pathname.new(file_path)
    filename_without_ext = path.basename(path.extname).to_s
    "#{url_prefix}#{filename_without_ext}"
  else
    "file://#{file_path}"
  end
end

def read_jsonl_path(path_cfg, reader_cls)
  index_file = File.expand_path(path_cfg.out)
  return [] unless File.exist?(index_file)

  file_cache = {}
  notes = []
  File.foreach(index_file).with_index do |line, idx|
    begin
      row = JSON.parse(line)
      emb = safe_float_array(row["embedding"])
      chunk_idx = row["chunk"].to_i
      file_path = row["path"]
      reader = file_cache[file_path] ||= reader_cls.new(file_path).load
      text = reader.get_chunk(chunk_idx)
      next if text.nil? || text.strip.empty?

      notes << {
        path: file_path,
        chunk: chunk_idx,
        hash: row["hash"],
        lookup: path_cfg.name,
        id: extract_id(file_path),
        url: extract_url(file_path, path_cfg.url),
        text: text,
        embedding: emb
      }
    rescue => e
      STDOUT << "[#{path_cfg.name}] JSONL line #{idx + 1} skipped: #{e.class}: #{e.message}\n"
    end
  end

  notes
end

def read_sqlite_path(path_cfg, reader_cls)
  file_cache = {}
  notes = []
  store = SqliteIndex.new(path_cfg.db_file, path_cfg.db_table)
  begin
    store.each_item do |row|
      file_path = row["path"]
      chunk_idx = row["chunk"].to_i
      reader = file_cache[file_path] ||= reader_cls.new(file_path).load
      text = row["text"] || reader.get_chunk(chunk_idx)
      next if text.nil? || text.strip.empty?

      notes << {
        path: file_path,
        chunk: chunk_idx,
        hash: row["hash"],
        lookup: path_cfg.name,
        id: extract_id(file_path),
        url: extract_url(file_path, path_cfg.url),
        text: text,
        embedding: safe_float_array(row["embedding"])
      }
    end
  ensure
    store.close
  end

  notes
end

def load_all_notes(paths)
  all = []
  paths.each do |path_cfg|
    reader_cls = get_reader(path_cfg.reader)
    if reader_cls.nil?
      STDOUT << %(Skip "#{path_cfg.name}": unknown reader "#{path_cfg.reader}"\n)
      next
    end

    notes = if path_cfg.db_file && path_cfg.db_table
      read_sqlite_path(path_cfg, reader_cls)
    else
      read_jsonl_path(path_cfg, reader_cls)
    end
    STDOUT << %(Loaded #{notes.length} notes from "#{path_cfg.name}"\n)
    all.concat(notes)
  end
  all
end

def choose_anchor_indices(embeddings)
  count = embeddings.length
  return [0, 0, 0] if count == 1
  return [0, 1, 0] if count == 2

  a = 0
  b = (0...count).max_by { |i| cosine_distance(embeddings[a], embeddings[i]) }
  c = (0...count).max_by do |i|
    [cosine_distance(embeddings[a], embeddings[i]), cosine_distance(embeddings[b], embeddings[i])].min
  end
  [a, b, c]
end

def normalize_to_canvas(values, min_px, max_px)
  return Array.new(values.length, (min_px + max_px) / 2.0) if values.empty?

  min_v = values.min
  max_v = values.max
  span = max_v - min_v
  return Array.new(values.length, (min_px + max_px) / 2.0) if span.abs < 1e-9

  values.map do |v|
    ratio = (v - min_v) / span.to_f
    min_px + ratio * (max_px - min_px)
  end
end

def desired_cluster_count(note_count)
  return 1 if note_count <= 30
  base = (Math.sqrt(note_count).to_f / 2.2).round
  [[base, MIN_CLUSTER_COUNT].max, MAX_CLUSTER_COUNT, note_count].min
end

def sq_dist(a, b)
  dx = a[0] - b[0]
  dy = a[1] - b[1]
  (dx * dx) + (dy * dy)
end

def kmeans_plus_plus(points, k, rng)
  centers = [points[rng.rand(points.length)].dup]
  while centers.length < k
    d2s = points.map do |p|
      centers.map { |c| sq_dist(p, c) }.min
    end
    total = d2s.inject(0.0, :+)
    if total <= 0.0
      centers << points[rng.rand(points.length)].dup
      next
    end

    pick = rng.rand * total
    running = 0.0
    chosen_idx = d2s.length - 1
    d2s.each_with_index do |d2, i|
      running += d2
      if running >= pick
        chosen_idx = i
        break
      end
    end
    centers << points[chosen_idx].dup
  end
  centers
end

def kmeans(points, k, seed_text)
  rng = Random.new(Digest::SHA256.hexdigest(seed_text)[0, 12].to_i(16) ^ points.length)
  centers = kmeans_plus_plus(points, k, rng)
  assignments = Array.new(points.length, 0)

  KMEANS_MAX_ITER.times do
    changed = false

    points.each_with_index do |p, idx|
      best_id = 0
      best_d2 = sq_dist(p, centers[0])
      (1...centers.length).each do |cid|
        d2 = sq_dist(p, centers[cid])
        next unless d2 < best_d2
        best_d2 = d2
        best_id = cid
      end
      if assignments[idx] != best_id
        assignments[idx] = best_id
        changed = true
      end
    end

    sums = Array.new(centers.length) { [0.0, 0.0, 0] }
    points.each_with_index do |p, idx|
      cid = assignments[idx]
      sums[cid][0] += p[0]
      sums[cid][1] += p[1]
      sums[cid][2] += 1
    end

    moved = 0.0
    centers.each_with_index do |c, cid|
      count = sums[cid][2]
      if count <= 0
        centers[cid] = points[rng.rand(points.length)].dup
        moved += 1.0
        next
      end
      nx = sums[cid][0] / count.to_f
      ny = sums[cid][1] / count.to_f
      moved += sq_dist(c, [nx, ny])
      centers[cid] = [nx, ny]
    end

    break unless changed
    break if moved <= KMEANS_EPSILON
  end

  [centers, assignments]
end

def merge_small_clusters(points, centers, assignments)
  loop do
    members = Hash.new { |h, k| h[k] = [] }
    assignments.each_with_index { |cid, idx| members[cid] << idx }
    small = members.select { |_, idxs| idxs.length < MIN_CLUSTER_SIZE }
    break if small.empty? || centers.length <= 1

    changed_any = false
    small.keys.each do |cid|
      idxs = members[cid]
      next if idxs.nil? || idxs.empty?
      next if centers.length <= 1

      target = nil
      best = Float::INFINITY
      centers.each_with_index do |center, other_cid|
        next if other_cid == cid
        d2 = sq_dist(centers[cid], center)
        if d2 < best
          best = d2
          target = other_cid
        end
      end
      next if target.nil?
      idxs.each { |i| assignments[i] = target }
      changed_any = true
    end

    break unless changed_any

    used_ids = assignments.uniq.sort
    remap = {}
    used_ids.each_with_index { |old_id, new_id| remap[old_id] = new_id }
    assignments.map! { |old| remap[old] }
    centers = used_ids.map { |old_id| centers[old_id] }
  end

  [centers, assignments]
end

def compute_cluster_stats(points, members)
  stats = {}
  members.each do |cid, idxs|
    cx = idxs.inject(0.0) { |s, i| s + points[i][0] } / idxs.length.to_f
    cy = idxs.inject(0.0) { |s, i| s + points[i][1] } / idxs.length.to_f
    dx = Math.sqrt(idxs.inject(0.0) { |s, i| s + ((points[i][0] - cx) ** 2) } / idxs.length.to_f)
    dy = Math.sqrt(idxs.inject(0.0) { |s, i| s + ((points[i][1] - cy) ** 2) } / idxs.length.to_f)
    stats[cid] = { cx: cx, cy: cy, dx: dx, dy: dy, count: idxs.length }
  end
  stats
end

def build_members_from_assignments(assignments)
  members = Hash.new { |h, cid| h[cid] = [] }
  assignments.each_with_index { |cid, idx| members[cid] << idx }
  members
end

def merge_small_communities(assignments, adjacency, min_size:)
  loop do
    members = build_members_from_assignments(assignments)
    small = members.select { |_cid, idxs| idxs.length < min_size }
    break if small.empty?

    changed = false
    small.keys.sort.each do |cid|
      idxs = members[cid]
      next if idxs.nil? || idxs.empty?

      score_by_community = Hash.new(0.0)
      idxs.each do |idx|
        adjacency[idx].each do |neighbor_idx, weight|
          neighbor_cid = assignments[neighbor_idx]
          next if neighbor_cid == cid
          score_by_community[neighbor_cid] += weight.to_f
        end
      end
      next if score_by_community.empty?

      target_cid, _best = score_by_community.sort_by { |other_cid, score| [-score, other_cid] }.first
      idxs.each { |idx| assignments[idx] = target_cid }
      changed = true
    end

    break unless changed
  end

  members = build_members_from_assignments(assignments)
  ordered = members.keys.sort_by { |cid| [-members[cid].length, cid] }
  remap = {}
  ordered.each_with_index { |cid, dense| remap[cid] = dense }
  assignments.map { |cid| remap[cid] }
end

def detect_communities_weighted_local_moving(adjacency, min_size:)
  node_count = adjacency.length
  assignments = Array.new(node_count) { |idx| idx }
  epsilon = 1e-9

  30.times do
    moved = false
    community_sizes = Hash.new(0)
    assignments.each { |cid| community_sizes[cid] += 1 }

    (0...node_count).each do |idx|
      current = assignments[idx]
      neighbor_scores = Hash.new(0.0)
      adjacency[idx].each do |neighbor_idx, weight|
        neighbor_scores[assignments[neighbor_idx]] += weight.to_f
      end
      next if neighbor_scores.empty?

      current_score = neighbor_scores[current].to_f / Math.sqrt([community_sizes[current], 1].max)
      best_cid = current
      best_score = current_score

      neighbor_scores.keys.sort.each do |candidate_cid|
        score = neighbor_scores[candidate_cid].to_f / Math.sqrt([community_sizes[candidate_cid], 1].max)
        if score > best_score + epsilon
          best_score = score
          best_cid = candidate_cid
        end
      end

      next if best_cid == current

      assignments[idx] = best_cid
      community_sizes[current] -= 1
      community_sizes[best_cid] += 1
      moved = true
    end

    break unless moved
  end

  merge_small_communities(assignments, adjacency, min_size: min_size)
end

def normalize_points_to_canvas!(points, width:, height:, margin:)
  return if points.empty?

  xs = points.map { |p| p[0] }
  ys = points.map { |p| p[1] }
  min_x, max_x = xs.minmax
  min_y, max_y = ys.minmax
  span_x = max_x - min_x
  span_y = max_y - min_y

  available_w = width - (2.0 * margin)
  available_h = height - (2.0 * margin)
  if span_x.abs < 1e-9 && span_y.abs < 1e-9
    cx = width / 2.0
    cy = height / 2.0
    points.each_with_index do |point, idx|
      angle = idx * Math::PI * (3.0 - Math.sqrt(5.0))
      radius = 2.0 + (idx % 11)
      point[0] = cx + (Math.cos(angle) * radius)
      point[1] = cy + (Math.sin(angle) * radius)
    end
    return
  end

  scale_x = span_x.abs < 1e-9 ? Float::INFINITY : (available_w / span_x.to_f)
  scale_y = span_y.abs < 1e-9 ? Float::INFINITY : (available_h / span_y.to_f)
  scale = [scale_x, scale_y].min
  scale = 1.0 if !scale.finite? || scale <= 0.0

  out_w = span_x * scale
  out_h = span_y * scale
  offset_x = margin + ((available_w - out_w) / 2.0)
  offset_y = margin + ((available_h - out_h) / 2.0)

  points.each do |point|
    point[0] = offset_x + ((point[0] - min_x) * scale)
    point[1] = offset_y + ((point[1] - min_y) * scale)
    point[0] = [[point[0], margin].max, width - margin].min
    point[1] = [[point[1], margin].max, height - margin].min
  end
end

def layout_graph_force(adjacency, communities, iterations:, width:, height:, margin:)
  node_count = adjacency.length
  members = build_members_from_assignments(communities)

  center_x = width / 2.0
  center_y = height / 2.0
  points = Array.new(node_count) do |idx|
    angle = idx * Math::PI * (3.0 - Math.sqrt(5.0))
    radius = 7.0 * Math.sqrt(idx + 1)
    [center_x + (Math.cos(angle) * radius), center_y + (Math.sin(angle) * radius)]
  end

  edges = []
  adjacency.each_with_index do |neighbors, i|
    neighbors.each do |j, w|
      next unless j > i
      edges << [i, j, w.to_f]
    end
  end

  iterations.times do |iter|
    forces = Array.new(node_count) { [0.0, 0.0] }

    edges.each do |a, b, w|
      dx = points[b][0] - points[a][0]
      dy = points[b][1] - points[a][1]
      dist = Math.sqrt((dx * dx) + (dy * dy))
      dist = 1.0 if dist < 1.0
      ux = dx / dist
      uy = dy / dist
      same = communities[a] == communities[b]
      ideal = same ? SAME_COMMUNITY_EDGE_IDEAL : CROSS_COMMUNITY_EDGE_IDEAL
      strength = same ? SAME_COMMUNITY_ATTRACTION : CROSS_COMMUNITY_ATTRACTION
      force = strength * w * (dist - ideal)
      fx = ux * force
      fy = uy * force
      forces[a][0] += fx
      forces[a][1] += fy
      forces[b][0] -= fx
      forces[b][1] -= fy
    end

    if node_count <= 1200
      node_count.times do |a|
        ((a + 1)...node_count).each do |b|
          dx = points[b][0] - points[a][0]
          dy = points[b][1] - points[a][1]
          dist2 = (dx * dx) + (dy * dy)
          dist2 = 16.0 if dist2 < 16.0
          dist = Math.sqrt(dist2)
          ux = dx / dist
          uy = dy / dist
          rep = 18.0 / dist2
          fx = ux * rep
          fy = uy * rep
          forces[a][0] -= fx
          forces[a][1] -= fy
          forces[b][0] += fx
          forces[b][1] += fy
        end
      end
    else
      offsets = [1, 7, 19, 43, 97, 211]
      node_count.times do |a|
        offsets.each do |offset|
          b = a + offset
          break if b >= node_count
          dx = points[b][0] - points[a][0]
          dy = points[b][1] - points[a][1]
          dist2 = (dx * dx) + (dy * dy)
          dist2 = 16.0 if dist2 < 16.0
          dist = Math.sqrt(dist2)
          ux = dx / dist
          uy = dy / dist
          rep = 18.0 / dist2
          fx = ux * rep
          fy = uy * rep
          forces[a][0] -= fx
          forces[a][1] -= fy
          forces[b][0] += fx
          forces[b][1] += fy
        end
      end
    end

    centroids = {}
    members.each do |cid, idxs|
      sx = 0.0
      sy = 0.0
      idxs.each do |idx|
        sx += points[idx][0]
        sy += points[idx][1]
      end
      centroids[cid] = [sx / idxs.length.to_f, sy / idxs.length.to_f]
    end

    node_count.times do |idx|
      centroid = centroids[communities[idx]]
      next if centroid.nil?

      forces[idx][0] += (centroid[0] - points[idx][0]) * COMMUNITY_GRAVITY
      forces[idx][1] += (centroid[1] - points[idx][1]) * COMMUNITY_GRAVITY
    end

    temperature = NODE_INITIAL_TEMP * (1.0 - (iter.to_f / iterations.to_f))
    max_step = [temperature, 1.0].max
    node_count.times do |idx|
      fx = forces[idx][0]
      fy = forces[idx][1]
      step = Math.sqrt((fx * fx) + (fy * fy))
      if step > max_step
        scale = max_step / step
        fx *= scale
        fy *= scale
      end

      points[idx][0] += fx
      points[idx][1] += fy
    end
  end

  raw_points = points.map(&:dup)
  normalize_points_to_canvas!(points, width: width, height: height, margin: margin)
  { points: points, raw_points: raw_points }
end

def node_graph_debug(adjacency, communities)
  debug = {}
  adjacency.each_with_index do |neighbors, idx|
    internal = 0.0
    external = 0.0
    neighbors.each do |neighbor_idx, weight|
      if communities[idx] == communities[neighbor_idx]
        internal += weight.to_f
      else
        external += weight.to_f
      end
    end

    total = internal + external
    debug[idx] = {
      community_id: communities[idx],
      degree: neighbors.length,
      internal_weight: internal,
      external_weight: external,
      bridge_score: total <= 0.0 ? 0.0 : external / total
    }
  end
  debug
end

def label_excerpt(text, max_chars = MAX_LABEL_CHARS)
  raw = text.to_s
  raw = strip_model_artifacts(raw)
  raw = raw.gsub(/https?:\/\/\S+/, " ")
  raw = raw.gsub(/\[\[[^\]|]+?\|([^\]]+)\]\]/, "\\1")
  raw = raw.gsub(/\[\[([^\]]+)\]\]/, "\\1")
  raw = raw.gsub(/\[([^\]]+)\]\([^)]+\)/, "\\1")
  raw = raw.gsub(/`{1,3}[^`]*`{1,3}/, " ")
  raw = raw.gsub(/<[^>]+>/, " ")
  raw = raw.gsub(/[*_~]/, " ")

  lines = raw.lines.map(&:strip).reject(&:empty?)
  while lines.first&.match?(/\A[#]{1,6}\s+/)
    lines.shift
  end

  cleaned = lines.join("\n")
  cleaned = cleaned.gsub(/\A[-*+]\s+/, "")
  cleaned = cleaned.gsub(/[#]{1,6}\s*/, "")
  cleaned = cleaned.gsub(/[>]+/, " ")
  cleaned = cleaned.gsub(/\s+/, " ").strip
  return "" if cleaned.empty?

  first_sentence = cleaned[/\A.*?[。.!?！？]/]
  first_line = lines.first.to_s
    .gsub(/\A[-*+]\s+/, "")
    .gsub(/[#]{1,6}\s*/, "")
    .gsub(/\s+/, " ")
    .strip

  candidate = [first_sentence, first_line, cleaned[0...max_chars]]
    .compact
    .map(&:strip)
    .reject(&:empty?)
    .min_by(&:length)

  candidate = candidate.to_s.gsub(/\s+/, " ").strip
  candidate.length > max_chars ? candidate[0...max_chars].strip : candidate
end

def map_snippet(text, max_chars = 360)
  raw = strip_model_artifacts(text.to_s)
  raw = raw.gsub(/\s+/, " ").strip
  return "" if raw.empty?

  raw.length > max_chars ? "#{raw[0...max_chars].strip}..." : raw
end

STOP_WORDS = %w[
  the and with from this that into about over under for not are was were been
  then than when where while what your you ours itself also have has had will
  they them their there here should could would can cannot etc markdown notes
  note todo task today yesterday tomorrow after before above below around
  key need road win thing idea topic theme concept content point issue
  summary every time elaborate usability tests chatgpt gpt prompt waste resources
].to_set

GENERIC_LABEL_WORDS = %w[
  win key need road attentio affirm keyevent greatapi response event thing idea
  topic theme concept content point issue summary every time elaborate usability tests
  chatgpt gpt prompt waste resources
].to_set

GENERIC_CHINESE_LABEL_FRAGMENTS = %w[
  它是 一种 这个 那个 我们 他们 你们 但是 如果 因为 所以 需要 可以
  通过 对于 关于 时候 进行 可能 重要 做事 和学习 学习时 干啥 和几
  智信 活企 活下去 建立自己 如何 永远是企 永远是 问题库 死胡同 过程性解 避免陷入 联系到
].freeze

def keywords_from_snippets(snippets, limit = 6)
  tokens = snippets.join(" ").scan(/[\p{Han}]{2,4}|[A-Za-z][A-Za-z0-9_\-]{2,}/)
  freq = Hash.new(0)
  tokens.each do |tok|
    key = tok.match?(/\p{Han}/) ? tok : tok.downcase
    next if STOP_WORDS.include?(key)
    next if key.match?(/\p{Han}/) && GENERIC_CHINESE_LABEL_FRAGMENTS.any? { |fragment| key.include?(fragment) }
    freq[key] += 1
  end
  freq.sort_by { |_, c| -c }.first(limit).map(&:first)
end

def strip_model_artifacts(text)
  text.to_s
      .gsub(/<think>.*?<\/think>/mi, " ")
      .gsub(/<\/?think>/i, " ")
      .gsub(/<\|[^>]*\|>/, "\n")
end

def clean_label_fragment(text)
  cleaned = strip_model_artifacts(text)
  cleaned = cleaned.gsub(/<[^>]+>/, " ")
  cleaned = cleaned.gsub(/([a-z])([A-Z])/, "\\1 \\2")
  cleaned = cleaned.gsub(/\b(?:label|name|title)\s*[:：]\s*/i, " ")
  cleaned = cleaned.gsub(/[\"'`“”‘’]/, "")
  cleaned = cleaned.gsub(/[()\[\]{}]/, " ")
  cleaned = cleaned.gsub(/[\\\/_|]+/, " ")
  cleaned = cleaned.gsub(/\bapi\b/i, "API")
  cleaned = cleaned.gsub(/\s+/, " ").strip
  cleaned = cleaned.gsub(/(\p{Han})\s+(\p{Han})/, "\\1\\2")
  cleaned = cleaned.gsub(/\A[-:：,，.。;；\s]+|[-:：,，.。;；\s]+\z/, "")
  cleaned
end

def usable_label?(label)
  cleaned = label.to_s.strip
  return false if cleaned.empty?
  return false if cleaned =~ /[<>]/
  return false if cleaned =~ /https?:|www\.|```/i
  return false if cleaned =~ /\b(?:cluster|mountain|label|note|filename|untitled)\b/i

  words = cleaned.scan(/[A-Za-z][A-Za-z0-9]*/).map(&:downcase)
  han_count = cleaned.scan(/\p{Han}/).length
  word_count = words.length
  normalized = cleaned.downcase.gsub(/\s+/, "")
  return false if GENERIC_LABEL_WORDS.include?(normalized)
  return false if words.any? { |word| GENERIC_LABEL_WORDS.include?(word) }
  if han_count >= 2
    return false if cleaned.length > 6
    return false if GENERIC_CHINESE_LABEL_FRAGMENTS.any? { |fragment| cleaned.include?(fragment) }
    return false if cleaned.include?("和")
    return false if cleaned.end_with?("几", "时", "但", "简")
    return true
  end
  return false if word_count == 1 && cleaned.length < 5
  return word_count <= 5 && cleaned.length <= 36 if word_count > 0

  cleaned.length <= 24
end

def sanitize_label(label)
  fragments = strip_model_artifacts(label)
    .split(/[\r\n]+|[。.!?！？；;]+/)
    .map { |fragment| clean_label_fragment(fragment) }
    .reject(&:empty?)

  cleaned = fragments.find { |fragment| usable_label?(fragment) } || fragments.first.to_s
  cleaned = clean_label_fragment(cleaned)
  return "" unless usable_label?(cleaned)

  words = cleaned.scan(/[A-Za-z][A-Za-z0-9]*/)
  if words.length > 5
    cleaned = words.first(5).join(" ")
  end

  cleaned[0, 42].strip
end

def label_key(label)
  clean_label_fragment(label).downcase.gsub(/\s+/, "")
end

def add_rejected_label(rejected_labels, candidate)
  cleaned = clean_label_fragment(candidate)
  cleaned = cleaned[0, 42].strip
  key = label_key(cleaned)
  return if key.empty?
  return if rejected_labels.any? { |existing| label_key(existing) == key }

  rejected_labels << cleaned
end

def xml_escape(text)
  text.to_s
      .gsub("&", "&amp;")
      .gsub("<", "&lt;")
      .gsub(">", "&gt;")
      .gsub("\"", "&quot;")
      .gsub("'", "&apos;")
end

def fallback_label(snippets, cluster_index, used_labels = Set.new)
  keywords = keywords_from_snippets(snippets, 10)
  words = keywords.select { |word| word.match?(/\p{Han}/) } +
          keywords.reject { |word| word.match?(/\p{Han}/) }

  words.each do |word|
    label = sanitize_label(word)
    next if label.empty?
    next if used_labels.include?(label_key(label))

    return label
  end

  english = keywords.reject { |word| word.match?(/\p{Han}/) }.first(3)
  unless english.empty?
    label = sanitize_label(english.join(" "))
    return label if !label.empty? && !used_labels.include?(label_key(label))
  end

  "主题#{cluster_index}"
end

def alternate_duplicate_label(label)
  chars = label.to_s.scan(/\p{Han}/)
  if chars.length == 4
    candidate = (chars[2, 2] + chars[0, 2]).join
    return candidate if usable_label?(candidate)
  end

  ""
end

def cluster_samples_for_labels(notes, points, members, stats, degree_scores: nil, ordered_cluster_ids: nil, neighbor_samples: nil)
  cluster_ids = ordered_cluster_ids || members.keys.sort
  cluster_ids.each_with_index.map do |cid, order_idx|
    idxs = members[cid]
    center = stats[cid]
    ordered = if degree_scores
      idxs.sort_by { |i| [-degree_scores[i].to_f, i] }
    else
      idxs.sort_by do |i|
        dx = points[i][0] - center[:cx]
        dy = points[i][1] - center[:cy]
        (dx * dx) + (dy * dy)
      end
    end

    sample_idxs = ordered.first([ordered.length, MAX_LABEL_SNIPPETS].min)

    snippets = sample_idxs.map { |i| label_excerpt(notes[i][:text]) }.reject(&:empty?)

    {
      cluster_id: cid,
      cluster_index: order_idx + 1,
      snippets: snippets,
      keywords: keywords_from_snippets(snippets, 8),
      neighbors: neighbor_samples&.fetch(cid, []) || []
    }
  end
end

def build_label_prompt(cluster_sample, used_labels: [], rejected_labels: [], attempt: 1)
  notes_xml = cluster_sample[:snippets].each_with_index.map do |snippet, idx|
    %(    <note rank="#{idx + 1}">#{xml_escape(snippet)}</note>)
  end.join("\n")
  used_xml = used_labels.last(24).map do |label|
    %(    <label>#{xml_escape(label)}</label>)
  end.join("\n")
  rejected_xml = rejected_labels.last(12).map do |label|
    %(    <label>#{xml_escape(label)}</label>)
  end.join("\n")
  neighbors_xml = cluster_sample[:neighbors].map do |neighbor|
    %(    <neighbor index="#{neighbor[:cluster_index]}"><keywords>#{xml_escape(neighbor[:keywords].join(", "))}</keywords></neighbor>)
  end.join("\n")
  neighbors_block = neighbors_xml.empty? ? "" : <<~NEIGHBORS

    Nearest neighboring clusters. Use these to make this label contrastive rather than generic:
    <neighbor_clusters>
#{neighbors_xml}
    </neighbor_clusters>
  NEIGHBORS
  retry_note = attempt > 1 ? "    - This is retry #{attempt}. The previous answer failed validation; choose a different valid label.\n" : ""
  used_block = used_xml.empty? ? "" : <<~USED

    Already used labels. Do not reuse any of these:
    <used_labels>
#{used_xml}
    </used_labels>
  USED
  rejected_block = rejected_xml.empty? ? "" : <<~REJECTED

    Rejected labels from previous attempts. Do not reuse these:
    <rejected_labels>
#{rejected_xml}
    </rejected_labels>
  REJECTED

  <<~PROMPT
    You are naming one knowledge mountain in a cognition map.
    The model is small, so keep reasoning private and output format strict.

    Return only strict JSON with keys: primaryLabel, subtitle, keywordChips.
    Rules:
    - Prefer a polished Chinese label of 2 to 6 characters.
    - If English is clearly better, use 1 to 3 words.
    - primaryLabel must be specific and contrast this cluster from neighboring clusters.
    - subtitle should be a concise phrase explaining the cluster focus.
    - keywordChips must contain exactly 3 short keywords.
    - Avoid generic labels like 职场智慧 unless no sharper label is possible.
    - Use neutral written style. Avoid slang, sentence fragments, and invented abbreviations.
    - Do not output reasoning, filenames, URLs, code syntax, XML tags, or explanations outside the JSON object.
    - Do not output special tokens such as <|endoftext|>, <think>, or </think>.
    - Do not use the words Cluster, Mountain, Label, or Note.
    - Avoid generic or broken labels like win, key, need, road, attentio, greatapi.
#{retry_note}

    Good style examples:
    关系沟通
    明智决策
    科学思维
    精英思维
    银行金融
    Self Regulation

    Bad style examples:
    干啥不顺
    招聘和几
    智信
    活企
    活下去
    建立自己
    如何坚持
    永远是企
    问题库
    死胡同
    过程性解
    避免陷入
    联系到
    win
    key
    summary every time
    elaborate usability tests
#{used_block}#{rejected_block}
#{neighbors_block}

    <cluster index="#{cluster_sample[:cluster_index]}">
      <keywords>#{xml_escape(cluster_sample[:keywords].join(", "))}</keywords>
      <notes>
#{notes_xml}
      </notes>
    </cluster>
  PROMPT
end

def sanitize_label_details(raw_response, fallback_keywords)
  parsed = JSON.parse(strip_model_artifacts(raw_response).to_s)
  primary = sanitize_label(parsed["primaryLabel"] || parsed[:primaryLabel])
  return nil if primary.empty?

  subtitle = clean_label_fragment(parsed["subtitle"] || parsed[:subtitle]).strip
  subtitle = subtitle[0, 60]
  chips_raw = parsed["keywordChips"] || parsed[:keywordChips] || []
  chips = Array(chips_raw)
    .map { |chip| clean_label_fragment(chip).strip }
    .reject(&:empty?)
    .first(3)
  fallback_keywords.each do |keyword|
    break if chips.length >= 3
    chip = clean_label_fragment(keyword).strip
    chips << chip unless chip.empty? || chips.include?(chip)
  end

  {
    primaryLabel: primary,
    subtitle: subtitle,
    keywordChips: chips.first(3)
  }
rescue JSON::ParserError, TypeError
  primary = sanitize_label(raw_response)
  return nil if primary.empty?

  {
    primaryLabel: primary,
    subtitle: "",
    keywordChips: fallback_keywords.first(3)
  }
end

def generate_cluster_labels(cluster_samples)
  return {} if cluster_samples.empty?

  labels = {}
  used_label_keys = Set.new
  used_label_texts = []
  cluster_samples.each do |cluster_sample|
    cluster_index = cluster_sample[:cluster_index]
    rejected_labels = []
    assigned_label = nil

    (1..MAX_LABEL_ATTEMPTS).each do |attempt|
      raw_response = nil
      begin
        prompt = build_label_prompt(
          cluster_sample,
          used_labels: used_label_texts,
          rejected_labels: rejected_labels,
          attempt: attempt
        )
        raw_response = chat([
          { role: ROLE_SYSTEM, content: "You output only strict JSON for the final map label." },
          { role: ROLE_USER, content: prompt }
        ]).to_s

        label = sanitize_label_details(raw_response, cluster_sample[:keywords])
        if label.nil? || label[:primaryLabel].to_s.empty?
          add_rejected_label(rejected_labels, raw_response)
          log_label_warning(
            "Empty label from LLM for cluster #{cluster_index} (attempt #{attempt}/#{MAX_LABEL_ATTEMPTS})",
            response: raw_response
          )
          next
        end

        key = label_key(label[:primaryLabel])
        if used_label_keys.include?(key)
          add_rejected_label(rejected_labels, label[:primaryLabel])
          log_label_warning(
            "Duplicate label from LLM for cluster #{cluster_index}: #{label[:primaryLabel]} (attempt #{attempt}/#{MAX_LABEL_ATTEMPTS})",
            response: raw_response
          )
          next
        end

        assigned_label = label
        break
      rescue => e
        add_rejected_label(rejected_labels, raw_response) unless raw_response.nil?
        log_label_warning(
          "LLM label generation failed for cluster #{cluster_index} (attempt #{attempt}/#{MAX_LABEL_ATTEMPTS})",
          response: raw_response,
          exception: e
        )
      end
    end

    if assigned_label.to_s.strip.empty?
      primary = fallback_label(cluster_sample[:snippets], cluster_index, used_label_keys)
      assigned_label = {
        primaryLabel: primary,
        subtitle: "",
        keywordChips: cluster_sample[:keywords].first(3)
      }
      log_label_warning(
        "Using fallback label for cluster #{cluster_index}: #{primary}"
      )
    end

    labels[cluster_index] = assigned_label
    used_label_keys.add(label_key(assigned_label[:primaryLabel]))
    used_label_texts << assigned_label[:primaryLabel]
  end

  labels
end

def prepare_notes_for_map!(notes)
  raise "No notes available. Run run-index first." if notes.empty?

  vector_dim = nil
  notes.each_with_index do |note, idx|
    emb = note[:embedding]
    if emb.nil? || emb.empty?
      raise "Missing embedding for note index #{idx} (#{note[:path]}##{note[:chunk]})"
    end
    vector_dim ||= emb.length
    if emb.length != vector_dim
      raise "Embedding dimension mismatch: expected=#{vector_dim}, got=#{emb.length}, note=#{note[:path]}##{note[:chunk]}"
    end
    normalized = safe_normalize(emb)
    raise "Zero-norm embedding at #{note[:path]}##{note[:chunk]}" if normalized.nil?
    note[:embedding] = normalized
  end

  vector_dim
end

def cluster_neighbor_samples(members, members_sorted, layout_edges, assignments, notes)
  cluster_index = {}
  members_sorted.each_with_index { |cid, idx| cluster_index[cid] = idx + 1 }
  snippets_by_cluster = {}
  members_sorted.each do |cid|
    snippets = members[cid].first(MAX_LABEL_SNIPPETS).map { |idx| label_excerpt(notes[idx][:text]) }.reject(&:empty?)
    snippets_by_cluster[cid] = snippets
  end

  scores = Hash.new(0.0)
  layout_edges.each do |edge|
    a = edge[:source]
    b = edge[:target]
    ca = assignments[a]
    cb = assignments[b]
    next if ca == cb
    left, right = ca < cb ? [ca, cb] : [cb, ca]
    scores[[left, right]] += edge[:weight].to_f
  end

  out = Hash.new { |h, k| h[k] = [] }
  scores.each do |(ca, cb), weight|
    out[ca] << { cluster_id: cb, cluster_index: cluster_index[cb], weight: weight }
    out[cb] << { cluster_id: ca, cluster_index: cluster_index[ca], weight: weight }
  end

  out.each do |cid, neighbors|
    out[cid] = neighbors
      .sort_by { |neighbor| [-neighbor[:weight], neighbor[:cluster_index]] }
      .first(4)
      .map do |neighbor|
        snippets = snippets_by_cluster[neighbor[:cluster_id]] || []
        {
          cluster_index: neighbor[:cluster_index],
          keywords: keywords_from_snippets(snippets, 6)
        }
      end
  end
  out
end

def build_map_payload(notes, points, assignments, members, final_stats, vector_dim, layout_meta: nil, degree_scores: nil, graph_debug: nil, raw_points: nil, layout_edges: nil)
  members_sorted = members.keys.sort_by { |cid| [-members[cid].length, cid] }
  neighbor_samples = cluster_neighbor_samples(members, members_sorted, layout_edges || [], assignments, notes)
  cluster_samples = cluster_samples_for_labels(
    notes,
    points,
    members,
    final_stats,
    degree_scores: degree_scores,
    ordered_cluster_ids: members_sorted,
    neighbor_samples: neighbor_samples
  )
  cluster_sample_by_id = {}
  cluster_samples.each { |sample| cluster_sample_by_id[sample[:cluster_id]] = sample }
  llm_labels = generate_cluster_labels(cluster_samples)

  cluster_id_order_map = {}
  final_label_keys = Set.new
  clusters = members_sorted.each_with_index.map do |cid, order_idx|
    stat = final_stats[cid]
    cluster_index = order_idx + 1
    cluster_id = "mountain-#{cluster_index}"
    cluster_id_order_map[cid] = cluster_id

    snippets = cluster_sample_by_id.fetch(cid, { snippets: [] })[:snippets]
    label_details = llm_labels[cluster_index] || {}
    label = label_details[:primaryLabel]
    if label.to_s.strip.empty?
      label = fallback_label(snippets, cluster_index, final_label_keys)
      label_details = {
        primaryLabel: label,
        subtitle: "",
        keywordChips: cluster_sample_by_id.fetch(cid, { keywords: [] })[:keywords].first(3)
      }
    end
    key = label_key(label)
    if final_label_keys.include?(key)
      label = fallback_label(snippets, cluster_index, final_label_keys)
      label_details = label_details.merge(primaryLabel: label)
      key = label_key(label)
    end
    final_label_keys.add(key)

    {
      id: cluster_id,
      label: label,
      primaryLabel: label,
      subtitle: label_details[:subtitle].to_s,
      keywordChips: Array(label_details[:keywordChips]).first(3),
      centerX: stat[:cx].round(2),
      centerY: stat[:cy].round(2),
      spreadX: (stat[:dx] + 36.0).round(2),
      spreadY: (stat[:dy] + 36.0).round(2),
      noteCount: stat[:count]
    }
  end

  notes_payload = notes.each_with_index.map do |n, idx|
    cid = assignments[idx]
    debug = graph_debug&.fetch(idx, {}) || {}
    {
      id: "#{n[:lookup]}::#{n[:path]}##{n[:chunk]}",
      index: idx,
      lookup: n[:lookup],
      path: n[:path],
      chunk: n[:chunk],
      hash: n[:hash],
      title: n[:id],
      url: n[:url],
      snippet: map_snippet(n[:text]),
      x: points[idx][0].round(2),
      y: points[idx][1].round(2),
      rawX: raw_points ? raw_points[idx][0].round(4) : nil,
      rawY: raw_points ? raw_points[idx][1].round(4) : nil,
      clusterId: cluster_id_order_map[cid],
      communityId: debug[:community_id] || cid,
      degree: debug[:degree] || 0,
      internalWeight: (debug[:internal_weight] || 0.0).round(4),
      externalWeight: (debug[:external_weight] || 0.0).round(4),
      bridgeScore: (debug[:bridge_score] || 0.0).round(4)
    }
  end

  edges_payload = Array(layout_edges).map do |edge|
    {
      sourceIndex: edge[:source],
      targetIndex: edge[:target],
      weight: edge[:weight].round(4),
      sameCommunity: !!edge[:same_community],
      bridge: !!edge[:bridge],
      mutual: !!edge[:mutual]
    }
  end

  payload = {
    generatedAt: Time.now.utc.iso8601,
    noteCount: notes_payload.length,
    vectorDim: vector_dim,
    width: MAP_WIDTH,
    height: MAP_HEIGHT,
    clusters: clusters,
    notes: notes_payload,
    edges: edges_payload
  }
  payload[:layout] = layout_meta if layout_meta
  payload
end

def build_map_data_with_kmeans(notes, vector_dim:, fallback_reason: nil)
  embeddings = notes.map { |n| n[:embedding] }
  a_idx, b_idx, c_idx = choose_anchor_indices(embeddings)
  a = embeddings[a_idx]
  b = embeddings[b_idx]
  c = embeddings[c_idx]

  raw_x = embeddings.map { |e| dot2(e, a) - dot2(e, b) }
  raw_y = embeddings.map { |e| dot2(e, c) - 0.5 * (dot2(e, a) + dot2(e, b)) }

  px = normalize_to_canvas(raw_x, MAP_MARGIN, MAP_WIDTH - MAP_MARGIN)
  py = normalize_to_canvas(raw_y, MAP_MARGIN, MAP_HEIGHT - MAP_MARGIN)
  points = px.each_with_index.map { |x, i| [x, py[i]] }

  k = desired_cluster_count(notes.length)
  centers, assignments = kmeans(points, k, "map-kmeans:#{notes.length}:#{vector_dim}")
  centers, assignments = merge_small_clusters(points, centers, assignments)

  members = build_members_from_assignments(assignments)
  final_stats = compute_cluster_stats(points, members)

  layout_meta = {
    method: "kmeans",
    layoutMethod: "global_embedding_projection",
    communityUsage: "ids_labels_metadata_only"
  }
  layout_meta[:fallbackReason] = fallback_reason if fallback_reason
  build_map_payload(notes, points, assignments, members, final_stats, vector_dim, layout_meta: layout_meta)
end

def build_map_data_with_graph(notes, vector_dim:)
  k = graph_knn_k(notes.length)
  min_size = graph_community_min_size
  min_edge_weight = graph_edge_min_weight
  iterations = map_layout_iterations

  directed_edges = build_knn_edges(notes, k: k, vector_dim: vector_dim)
  graph = symmetrize_knn_edges(directed_edges, node_count: notes.length, min_weight: min_edge_weight)
  adjacency = graph[:adjacency]
  edges = graph[:edges]
  STDOUT << "Undirected edges: #{edges.length}\n"
  if edges.empty?
    raise ArgumentError, "kNN graph has no usable edges; lower map.graphEdgeMinWeight or check sqlite-vec vector search results"
  end

  assignments = detect_communities_weighted_local_moving(adjacency, min_size: min_size)
  assignments.each_with_index { |cid, idx| notes[idx][:community_id] = cid }
  members = build_members_from_assignments(assignments)
  if members.length > MAP_MAX_GRAPH_COMMUNITIES
    raise ArgumentError, "Graph community count too high (#{members.length}); check kNN graph connectivity or increase map.communityMinSize"
  end
  STDOUT << "Detected communities: #{members.length}\n"
  layout_edges = retain_layout_edges(
    edges,
    assignments,
    cross_per_node: MAP_CROSS_COMMUNITY_EDGES_PER_NODE
  )
  layout_graph = graph_from_edges(layout_edges, node_count: notes.length)
  layout_adjacency = layout_graph[:adjacency]
  bridge_count = layout_edges.count { |edge| edge[:bridge] }
  STDOUT << "Retained layout edges: #{layout_edges.length} (bridges=#{bridge_count})\n"
  STDOUT << "Running force layout: iterations=#{iterations}\n"

  layout_result = layout_graph_force(
    layout_adjacency,
    assignments,
    iterations: iterations,
    width: MAP_WIDTH,
    height: MAP_HEIGHT,
    margin: MAP_MARGIN
  )
  points = layout_result[:points]
  raw_points = layout_result[:raw_points]
  final_stats = compute_cluster_stats(points, members)
  graph_debug = node_graph_debug(layout_adjacency, assignments)
  degree_scores = graph_debug.transform_values { |debug| debug[:internal_weight] }

  layout_meta = {
    method: "graph",
    knnK: k,
    retainedCrossCommunityEdgesPerNode: MAP_CROSS_COMMUNITY_EDGES_PER_NODE,
    communityMethod: "weighted_local_moving",
    communityUsage: "ids_labels_metadata_only",
    layoutMethod: "global_force_directed",
    edgeCount: edges.length,
    retainedEdgeCount: layout_edges.length,
    bridgeEdgeCount: bridge_count,
    sameCommunityIdealLength: SAME_COMMUNITY_EDGE_IDEAL,
    crossCommunityIdealLength: CROSS_COMMUNITY_EDGE_IDEAL,
    sameCommunityAttraction: SAME_COMMUNITY_ATTRACTION,
    crossCommunityAttraction: CROSS_COMMUNITY_ATTRACTION,
    communityGravity: COMMUNITY_GRAVITY
  }
  build_map_payload(
    notes,
    points,
    assignments,
    members,
    final_stats,
    vector_dim,
    layout_meta: layout_meta,
    degree_scores: degree_scores,
    graph_debug: graph_debug,
    raw_points: raw_points,
    layout_edges: layout_edges
  )
end

def build_map_data(notes)
  vector_dim = prepare_notes_for_map!(notes)
  requested_layout = map_layout_requested
  requested_layout ||= MAP_LAYOUT_DEFAULT
  STDOUT << "Map layout requested: #{requested_layout}\n"
  STDOUT << "sqlite-vec available: #{sqlite_vec_available?}\n"

  if graph_layout_enabled?
    STDOUT << "Map layout: graph\n"
    begin
      return build_map_data_with_graph(notes, vector_dim: vector_dim)
    rescue GraphDependencyError => e
      STDOUT << "sqlite-vec unavailable on this platform; falling back to kmeans layout\n"
      return build_map_data_with_kmeans(notes, vector_dim: vector_dim, fallback_reason: e.message)
    end
  end

  STDOUT << "Map layout: kmeans\n"
  build_map_data_with_kmeans(notes, vector_dim: vector_dim)
end

begin
  map_out_file = map_out_file!

  if should_start_ollama?
    ok = OllamaService.ensure_started(CONFIG)
    exit 9 unless ok
  end

  target_paths = resolve_target_paths
  STDOUT << "Selected paths: #{target_paths.map(&:name).join(", ")}\n"

  notes = load_all_notes(target_paths)
  map_data = build_map_data(notes)

  out_dir = File.dirname(map_out_file)
  FileUtils.mkdir_p(out_dir) unless Dir.exist?(out_dir)
  File.write(map_out_file, JSON.pretty_generate(map_data))

  STDOUT << "Map data generated: #{map_out_file}\n"
  STDOUT << "Notes: #{map_data[:noteCount]}, mountains: #{map_data[:clusters].length}, vector_dim: #{map_data[:vectorDim]}\n"
rescue => e
  STDOUT << "run-index-map failed: #{e.class}: #{e.message}\n"
  STDOUT << "Backtrace: #{e.backtrace&.first}\n"
  exit 1
end
