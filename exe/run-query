#!/usr/bin/env ruby
# encoding: utf-8

require "json"
require "optparse"
begin
  require "bundler/setup"
rescue LoadError
end

require_relative "../lib/config_path_resolver"
require_relative "../lib/query_helpers"
require_relative "../lib/query_server_client"

DEFAULT_LIMIT = 10
VALID_FORMATS = %w[json jsonl text].freeze

options = {
  config: nil,
  limit: DEFAULT_LIMIT,
  format: "json",
  concise: true,
  brief_chars: QueryHelpers::DEFAULT_BRIEF_CHARS,
  paths: [],
}

show_help = false

parser = OptionParser.new do |opts|
  opts.banner = "Usage: run-query [options] \"query text\""
  opts.separator ""
  opts.separator "Examples:"
  opts.separator "  run-query \"habit loop\""
  opts.separator "  run-query --paths learning,talks --limit 20 \"systems thinking\""
  opts.separator ""
  opts.separator "Options:"

  opts.on("-c", "--config FILE", "Config file path (default lookup: ./config.json, then ~/.config/simple-rag/config.json)") do |v|
    options[:config] = v
  end

  opts.on("-p", "--paths NAMES", "Comma-separated path names to search") do |v|
    options[:paths] = v.to_s.split(",").map(&:strip).reject(&:empty?).uniq
  end

  opts.on("-l", "--limit N", Integer, "Top files limit (default: #{DEFAULT_LIMIT})") do |v|
    options[:limit] = v
  end

  opts.on("-f", "--format FORMAT", VALID_FORMATS, "Output format: #{VALID_FORMATS.join(', ')}") do |v|
    options[:format] = v
  end

  opts.on("--concise", "Concise output with short chunk text (default)") do
    options[:concise] = true
  end

  opts.on("--full", "Full output with debug metadata and complete chunk text") do
    options[:concise] = false
  end

  opts.on("--brief-chars N", Integer, "Max chars for concise chunk text (default: #{QueryHelpers::DEFAULT_BRIEF_CHARS})") do |v|
    options[:brief_chars] = v
  end

  opts.on("-h", "--help", "Show this help and list searchable paths") do
    show_help = true
  end
end

def print_paths_for_help(config_arg)
  require_relative "../lib/config_loader"

  abs_config = ConfigPathResolver.resolve_config_path(config_arg)
  unless abs_config
    STDOUT << "\nPaths: #{ConfigPathResolver.default_search_message}\n"
    return
  end

  unless File.exist?(abs_config)
    STDOUT << "\nPaths: config file not found (#{abs_config})\n"
    return
  end

  begin
    config = ConfigLoader.load_config(abs_config, with_path_map: true)
  rescue => e
    STDOUT << "\nPaths: unable to load config (#{e.message})\n"
    return
  end

  STDOUT << "\nSearchable paths (name => dir)\n"
  config.paths.each do |path|
    marker = path.searchDefault ? " [default]" : ""
    STDOUT << "- #{path.name} => #{path.dir}#{marker}\n"
  end
end

def validate_options!(options)
  raise ArgumentError, "--limit must be > 0" unless options[:limit].to_i > 0
  raise ArgumentError, "--limit must be <= #{QueryHelpers::MAX_TOP_N}" if options[:limit].to_i > QueryHelpers::MAX_TOP_N
  raise ArgumentError, "--brief-chars must be > 0" unless options[:brief_chars].to_i > 0
end

def print_output(format, payload, concise)
  case format
  when "json"
    STDOUT << JSON.pretty_generate(concise ? payload[:data] : payload) << "\n"
  when "jsonl"
    payload[:data].each { |row| STDOUT << row.to_json << "\n" }
  when "text"
    payload[:data].each_with_index do |row, idx|
      score = format("%.4f", row[:score].to_f)
      anchor = concise ? row : row[:anchor_chunk]
      lookup = concise ? "" : "[#{row[:lookup]}] "
      STDOUT << "#{idx + 1}. #{lookup}#{row[:path]}##{anchor[:chunk]} score=#{score}\n"
      STDOUT << "#{concise ? '   ' : ''}#{anchor[:text]}\n"
      STDOUT << "\n" unless concise
    end
  else
    raise ArgumentError, "Unsupported format: #{format}"
  end
end

begin
  parser.parse!(ARGV)
  validate_options!(options)
rescue OptionParser::ParseError, ArgumentError => e
  STDOUT << "#{e.message}\n\n#{parser}\n"
  exit 1
end

if show_help
  STDOUT << parser.to_s << "\n"
  print_paths_for_help(options[:config])
  exit 0
end

query = ARGV.join(" ").to_s.strip
if query.empty?
  STDOUT << "Query text is required.\n\n#{parser}\n"
  exit 1
end

config_file = ConfigPathResolver.resolve_config_path(options[:config])
unless config_file
  STDOUT << "#{ConfigPathResolver.default_search_message}\n"
  exit 1
end

begin
  payload = QueryServerClient.retrieve(
    config_file: config_file,
    query: query,
    path_names: options[:paths],
    top_n: options[:limit]
  )
rescue QueryServerClient::QueryError => e
  STDOUT << "#{e.message}\n"
  exit 1
end

lookup_paths = nil
unless payload
  require_relative "../lib/config_loader"
  require_relative "../server/retriever"
  require_relative "../lib/ollama_service"
  require_relative "../lib/provider_env_validator"

  begin
    CONFIG = ConfigLoader.load_config(config_file, with_path_map: true)
  rescue => e
    STDOUT << "Config error: #{e.message}\n"
    exit 1
  end

  lookup_paths = QueryHelpers.resolve_lookup_paths(CONFIG, options[:paths], default_to_search_default: true)
  if lookup_paths.empty?
    STDOUT << "No lookup paths selected. Check --paths names or config paths.\n"
    exit 1
  end

  exit 9 unless OllamaService.ensure_started(CONFIG, sections: [:embedding])

  key_error = ProviderEnvValidator.missing_key_message(CONFIG, sections: [:embedding])
  if key_error
    STDOUT << "#{key_error}\n"
    exit 9
  end

  begin
    payload = build_retriever.retrieve_q(lookup_paths, query, top_n: options[:limit])
  rescue RetrievalInputError => e
    STDOUT << "#{e.message}\n"
    exit 1
  end
end

payload[:concise] = options[:concise]
payload[:limit] = options[:limit]
payload[:data] = QueryHelpers.compact_file_results(payload[:data], brief_chars: options[:brief_chars]) if options[:concise]
unless options[:concise]
  unless lookup_paths
    require_relative "../lib/config_loader"
    config = ConfigLoader.load_config(config_file, with_path_map: true)
    lookup_paths = QueryHelpers.resolve_lookup_paths(config, options[:paths], default_to_search_default: true)
  end
  payload[:paths] = lookup_paths.map { |path| { name: path.name, dir: path.dir } }
end

print_output(options[:format], payload, options[:concise])
